---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  current?: "home" | "data-science";
  canonicalUrl?: string;
}

const {
  title = "Anastasiia Selezen — Agentic AI Engineer",
  description = "Portfolio of Anastasiia Selezen, an Agentic AI Engineer focused on designing and building end-to-end, production-grade AI systems with LLMs, MCP-based tool layers, RAG, and applied machine learning.",
  current,
  canonicalUrl = Astro.url.href,
} = Astro.props;

const isDefaultTitle = title.startsWith("Anastasiia Selezen");
const pageTitle = isDefaultTitle ? title : `${title} · Anastasiia Selezen`;

const nav = [
  { href: "/", label: "Current Work", id: "home" },
  { href: "/data-science/", label: "Data Science Archive", id: "data-science" },
] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d0c0e" />
    <meta name="color-scheme" content="dark" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400..600;1,8..60,400..600&display=swap"
    />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/" aria-label="Anastasiia Selezen — home">
          <strong>Anastasiia Selezen</strong>
          <span>Agentic AI Engineer</span>
        </a>
        <nav class="nav" aria-label="Main navigation">
          {
            nav.map((item) => (
              <a
                href={item.href}
                aria-current={current === item.id ? "page" : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>
      <slot />
      <footer class="footer">
        <div class="footer-inner">
          <span>&copy; 2026 Anastasiia Selezen</span>
          <div class="footer-links">
            <a
              href="https://www.linkedin.com/in/anastasiia-selezen"
              target="_blank"
              rel="noopener noreferrer">LinkedIn</a
            >
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
