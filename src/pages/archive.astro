---
const target = "/data-science/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirect</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>{target}</a>.</p>
  </body>
</html>
